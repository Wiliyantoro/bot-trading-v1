# ==============================
# TRAILING
# ==============================
TP_BASE_INTERVAL=1.0
TP_INTERVAL_FAST=0.5
TP_INTERVAL_FASTER=0.2

TRAILING_BUFFER_MULTIPLIER=1.2
TRAILING_DYNAMIC_STEP_SPREAD_MULTIPLIER=2.0
TRAILING_TP_MULTIPLIER_BASE=0.0015
TRAILING_TP_MULTIPLIER_BOOSTED=0.0025
TRAILING_TP_BOOST_TRIGGER_MULTIPLIER=2.0
TRAILING_TP_FAST_INTERVAL_TRIGGER_MULTIPLIER=2.0
TRAILING_TP_FASTER_INTERVAL_TRIGGER_MULTIPLIER=3.0
TRAILING_VOLATILE_SPREAD_THRESHOLD=0.4
TRAILING_VOLATILE_TP_WIDEN_MULTIPLIER=1.5
TRAILING_TP_DISTANCE_SPREAD_MULTIPLIER=5.0
TRAILING_CHANGE_TOLERANCE_POINT=0.5

# ==============================
# STRATEGY
# ==============================
MARKET_MODE_TIMEFRAME=M1
