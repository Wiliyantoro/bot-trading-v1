# ==============================
# SYMBOLS (comma separated)
# ==============================
SYMBOLS=XAUUSDm,BTCUSDm

# ==============================
# PER-SYMBOL CONFIG
# Prefix format: <SYMBOL_ALNUM_UPPER>_<KEY>
# Example: XAUUSDM_LOT, BTCUSDM_LOT
# ==============================
XAUUSDM_LOT=0.01
XAUUSDM_MULTIPLIER=1.0
XAUUSDM_MAX_SPREAD=0.5
XAUUSDM_SL_POINTS=800
XAUUSDM_TP_POINTS=1200
XAUUSDM_TRAILING_START=400
XAUUSDM_TRAILING_STEP=100

BTCUSDM_LOT=0.01
BTCUSDM_MULTIPLIER=2.0
BTCUSDM_MAX_SPREAD=50.0
BTCUSDM_SL_POINTS=3000
BTCUSDM_TP_POINTS=6000
BTCUSDM_TRAILING_START=1000
BTCUSDM_TRAILING_STEP=500

# ==============================
# TRADING / SYSTEM
# ==============================
MIN_ENTRY_DISTANCE=0.4
MAGIC_NUMBER=121241
SLIPPAGE=10
TRADING_MODE=AUTO
# STRATEGY MODE
# AUTO = breakout + reversal otomatis
# BREAKOUT = hanya breakout
# REVERSAL = hanya reversal
# SWITCH = price switching pending order
# POINT = buy/sell point detector
STRATEGY_MODE=AUTO
# SWITCH STRATEGY
SWITCH_DISTANCE=0.4
SWITCH_FOLLOW_MULTIPLIER=0.5
SWITCH_MAX_DISTANCE=1.0
# POINT STRATEGY
POINT_LOOKBACK=20
POINT_WICK_RATIO=1.5
POINT_BODY_THRESHOLD=0.3
POINT_MA_PERIOD=20
POINT_MIN_DISTANCE=0.4
POINT_MIN_VOLATILITY=1.0
POINT_COOLDOWN=25
COOLDOWN_SECONDS=25

# ==============================
# LOOP TIMING (seconds)
# ==============================
SLEEP_NO_TICK=2
SLEEP_NO_SYMBOL=2
SLEEP_EMPTY_POSITIONS=2
SLEEP_NEW_POSITION=1
SLEEP_AFTER_POSITION_CYCLE=2
SLEEP_MANUAL_MODE=3
SLEEP_COOLDOWN=2
SLEEP_SPREAD_BLOCK=2
SLEEP_PENDING_BLOCK=2
SLEEP_LOOP_END=5

# ==============================
# FEATURE TOGGLES
# ==============================
ENABLE_DYNAMIC_SL=false
ENABLE_DYNAMIC_BE=false
ENABLE_BASIC_BE=true

# ==============================
# ORDER / POSITION SAFETY
# ==============================
ORDER_VALIDATE_BUFFER_MULTIPLIER=1.5
POSITION_SLTP_BUFFER_MULTIPLIER=1.5
POSITION_CHANGE_TOLERANCE_POINT=0.5

FAST_CUT_WINDOW_1_START=5
FAST_CUT_WINDOW_1_END=10
FAST_CUT_LEVEL_1_OFFSET=1.0

FAST_CUT_WINDOW_2_START=20
FAST_CUT_WINDOW_2_END=30
FAST_CUT_LEVEL_2_OFFSET=0.5

# ==============================
# BREAK EVEN
# ==============================
BE_TRIGGER=0.5
BE_OFFSET=0.1
BE_MIN_PROFIT=0.1
BE_BUFFER_MULTIPLIER=1.2

BE_STEP_1_START=10
BE_STEP_1_END=20
BE_STEP_1_LOCK=0.1

BE_STEP_2_START=20
BE_STEP_2_END=30
BE_STEP_2_LOCK=0.2

BE_STEP_3_START=30
BE_STEP_3_END=40
BE_STEP_3_LOCK=0.3

BE_STEP_4_START=40
BE_STEP_4_END=50
